  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "file-saver": "^2.0.5",
    "jwt-decode": "^4.0.0",
    "ng2-charts": "^9.0.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.20",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.2",
